# ============================================
# Team Management - Docker Deployment Config
# Copy to .env and fill in secrets
# ============================================

# PostgreSQL
POSTGRES_USER=tm_admin
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=team_management

# JWT (REQUIRED - generate: openssl rand -base64 64)
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_STRING
JWT_EXPIRES_IN=7d

# MinIO / S3
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=team-management
